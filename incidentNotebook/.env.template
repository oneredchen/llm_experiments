# Any OpenAI-v1-compatible LLM server. Note the required /v1 suffix.
LLM_BASE_URL=http://192.168.50.21:11434/v1
# LLM_BASE_URL=http://localhost:11434/v1      # Ollama (local)
# LLM_BASE_URL=http://localhost:1234/v1       # LM Studio
# LLM_BASE_URL=http://localhost:8000/v1       # vLLM

# Local servers accept any non-empty key.
LLM_API_KEY=local

# Structured-output mode: native (OpenAI json_schema response_format) or
# prompted (schema injected into the prompt — fallback for servers that
# reject json_schema).
# LLM_OUTPUT_MODE=native
